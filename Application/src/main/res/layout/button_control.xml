<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondocarbono"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/screen_padding_vertical"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/top_bar_margin_top"
            android:layout_marginBottom="@dimen/top_bar_margin_bottom"
            android:paddingStart="@dimen/top_bar_padding_horizontal"
            android:paddingEnd="@dimen/top_bar_padding_horizontal"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDemoTop"
                android:layout_width="0dp"
                android:layout_height="@dimen/top_button_height"
                android:layout_marginEnd="@dimen/top_bar_inner_spacing"
                android:layout_weight="1"
                android:background="@drawable/button_demo"
                android:text=""
                android:textAllCaps="false"
                android:textColor="#D4A61E"
                android:textSize="@dimen/top_button_text_size"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCenterTop"
                android:layout_width="@dimen/top_icon_width"
                android:layout_height="@dimen/top_icon_height"
                android:layout_marginEnd="@dimen/top_bar_inner_spacing"
                android:background="@drawable/logosinfondo"
                android:contentDescription="Centro"
                android:padding="@dimen/top_icon_padding"
                android:scaleType="fitCenter" />

            <Button
                android:id="@+id/btnBluetoothTop"
                android:layout_width="0dp"
                android:layout_height="@dimen/top_button_height"
                android:layout_weight="1"
                android:background="@drawable/button_bluetooth"
                android:text=""
                android:textAllCaps="false"
                android:textColor="#D4A61E"
                android:textSize="@dimen/top_button_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/Logoaccbox"
            android:maxHeight="@dimen/logo_max_height"
            android:onClick="onClickEstado"
            android:scaleType="fitCenter"
            android:src="@drawable/logoandroid" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/logo_bottom_spacing" />

        <Button
            android:id="@+id/buttonE"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:onClick="onClickEstado"
            android:text="@string/ButtonE"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/data_value"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:textSize="12sp"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/data_name"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:textSize="12sp"
            android:visibility="invisible" />

        <LinearLayout
            android:id="@+id/mainButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/main_buttons_container_margin_top"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <Button
                android:id="@+id/buttonR"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/main_button_width"
                android:layout_height="@dimen/main_button_height"
                android:layout_marginStart="@dimen/main_button_margin_start"
                android:layout_marginEnd="@dimen/main_button_margin_end"
                android:layout_marginBottom="@dimen/main_button_margin_bottom"
                android:background="@drawable/button_race"
                android:minHeight="@dimen/main_button_min_height"
                android:onClick="onClickRace" />

            <Button
                android:id="@+id/buttonS"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/main_button_width"
                android:layout_height="@dimen/main_button_height"
                android:layout_marginStart="@dimen/main_button_margin_start"
                android:layout_marginEnd="@dimen/main_button_margin_end"
                android:layout_marginBottom="@dimen/main_button_margin_bottom"
                android:background="@drawable/button_sport"
                android:minHeight="@dimen/main_button_min_height"
                android:onClick="onClickSport" />

            <Button
                android:id="@+id/buttonC"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/main_button_width"
                android:layout_height="@dimen/main_button_height"
                android:layout_marginStart="@dimen/main_button_margin_start"
                android:layout_marginEnd="@dimen/main_button_margin_end"
                android:layout_marginBottom="@dimen/main_button_margin_bottom"
                android:background="@drawable/button_city"
                android:minHeight="@dimen/main_button_min_height"
                android:onClick="onClickCity" />

            <Button
                android:id="@+id/buttonN"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/main_button_width"
                android:layout_height="@dimen/main_button_height"
                android:layout_marginStart="@dimen/main_button_margin_start"
                android:layout_marginEnd="@dimen/main_button_margin_end"
                android:layout_marginBottom="@dimen/main_button_margin_bottom"
                android:background="@drawable/button_normal"
                android:minHeight="@dimen/main_button_min_height"
                android:onClick="onClickNormal" />

            <Button
                android:id="@+id/buttonEco"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/main_button_width"
                android:layout_height="@dimen/main_button_height"
                android:layout_marginStart="@dimen/main_button_margin_start"
                android:layout_marginEnd="@dimen/main_button_margin_end"
                android:layout_marginBottom="@dimen/main_button_margin_bottom"
                android:background="@drawable/button_eco"
                android:minHeight="@dimen/main_button_min_height"
                android:onClick="onClickEco" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/starsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/stars_container_margin_horizontal"
            android:layout_marginEnd="@dimen/stars_container_margin_horizontal"
            android:gravity="center"
            android:minHeight="@dimen/stars_container_min_height"
            android:orientation="horizontal">

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/imageViewM5"
                android:layout_width="@dimen/star_w_5"
                android:layout_height="@dimen/star_h"
                android:contentDescription="ImageViewM5"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#27F802" />

            <ImageView
                android:id="@+id/imageViewM4"
                android:layout_width="@dimen/star_w_4"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewM4"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#5FF644" />

            <ImageView
                android:id="@+id/imageViewM3"
                android:layout_width="@dimen/star_w_3"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewM3"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#85F371" />

            <ImageView
                android:id="@+id/imageViewM2"
                android:layout_width="@dimen/star_w_2"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewM2"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#AAF69D" />

            <ImageView
                android:id="@+id/imageViewM1"
                android:layout_width="@dimen/star_w_1"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewM1"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#C5F8BC" />

            <ImageView
                android:id="@+id/imageViewP1"
                android:layout_width="@dimen/star_w_1"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewP1"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#FAB6B6" />

            <ImageView
                android:id="@+id/imageViewP2"
                android:layout_width="@dimen/star_w_2"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewP2"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#FF8484" />

            <ImageView
                android:id="@+id/imageViewP3"
                android:layout_width="@dimen/star_w_3"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewP3"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#FD5E5E" />

            <ImageView
                android:id="@+id/imageViewP4"
                android:layout_width="@dimen/star_w_4"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewP4"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#FF2828" />

            <ImageView
                android:id="@+id/imageViewP5"
                android:layout_width="@dimen/star_w_5"
                android:layout_height="@dimen/star_h"
                android:contentDescription="@string/ImageViewP5"
                android:src="@android:drawable/editbox_dropdown_light_frame"
                android:tint="#FF0000" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/plusMinusContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/plus_minus_container_margin_start"
            android:layout_marginTop="@dimen/plus_minus_container_margin_top"
            android:layout_marginEnd="@dimen/plus_minus_container_margin_end"
            android:layout_marginBottom="@dimen/plus_minus_container_margin_bottom"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonMenos"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/plus_minus_button_width"
                android:layout_height="@dimen/plus_minus_button_height"
                android:background="@drawable/button_less"
                android:onClick="onClickMenos"
                android:textColor="@android:color/black" />

            <Button
                android:id="@+id/buttonPlus"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/plus_minus_button_width"
                android:layout_height="@dimen/plus_minus_button_height"
                android:background="@drawable/button_more"
                android:onClick="onClickPlus"
                android:textColor="@android:color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bottomButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/bottom_container_margin_horizontal"
            android:layout_marginTop="@dimen/bottom_container_margin_top"
            android:layout_marginEnd="@dimen/bottom_container_margin_horizontal"
            android:layout_marginBottom="@dimen/bottom_container_margin_bottom"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonP"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/bottom_button_size"
                android:layout_height="@dimen/bottom_button_size"
                android:background="@drawable/button_parking"
                android:onClick="onClickPark"
                android:textColor="@android:color/transparent" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/buttonB"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="@dimen/bottom_button_size"
                android:layout_height="@dimen/bottom_button_size"
                android:background="@drawable/button_block"
                android:onClick="onClickBlock"
                android:text="B"
                android:textColor="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>