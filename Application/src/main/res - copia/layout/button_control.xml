<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9E9E7"
    android:gravity="center_vertical"
    android:orientation="vertical">


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="logoaccbox"
        android:onClick="onClickEstado"
        android:layout_margin="10dp"
        android:scaleType="fitXY"
        android:src="@drawable/logoandroid"

        />

    <TextView
        android:id="@+id/data_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:visibility="invisible" />
    <TextView
        android:id="@+id/data_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:visibility="invisible" />


    <Button
        android:id="@+id/buttonN"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFC9C9C8"
        android:onClick="onClickNormal"
        android:text="Normal"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button0"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#4B4B4B"
        android:visibility="invisible" />

    <Button
        android:id="@+id/buttonC"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFC9C9C8"
        android:onClick="onClickCity"
        android:text="City"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#4B4B4B"
        android:visibility="invisible" />

    <Button
        android:id="@+id/buttonS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFC9C9C8"
        android:onClick="onClickSport"
        android:text="Sport"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button3"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#4B4B4B"
        android:visibility="invisible" />

    <Button
        android:id="@+id/buttonR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFC9C9C8"
        android:onClick="onClickRace"
        android:text="Race"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonE"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C9C9C8"
        android:onClick="onClickEstado"
        android:text="Read"
        android:visibility="invisible" />

    <Button
        android:id="@+id/buttonP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFC9C9C8"
        android:onClick="onClickPark"
        android:text="Park"
        android:textStyle="bold" />

</LinearLayout>